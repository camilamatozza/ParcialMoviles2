<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PaisesApp.ViewModels"
             x:Class="PaisesApp.MainPage"
             Title="Países del Mundo">

    <ContentPage.BindingContext>
        <vm:PaisesViewModel/>
    </ContentPage.BindingContext>

    <VerticalStackLayout Padding="20" Spacing="12">

        <Label Text="🌍 Países del Mundo"
               FontSize="26"
               FontAttributes="Bold"
               HorizontalOptions="Center"/>

        <Button Text="Cargar Países"
                Command="{Binding CargarCommand}"
                BackgroundColor="#1565C0"
                TextColor="White"
                CornerRadius="10"
                HeightRequest="48"/>

        <Label Text="{Binding Mensaje}"
               FontSize="13"
               TextColor="Gray"
               HorizontalOptions="Center"/>

        <CollectionView ItemsSource="{Binding Paises}"
                        HeightRequest="520">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,4" Padding="14"
                            StrokeShape="RoundRectangle 10"
                            Stroke="#DDDDDD">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnPaisTapped"/>
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout Spacing="12">
                            <Label Text="🌎" FontSize="22"/>
                            <VerticalStackLayout>
                                <Label Text="{Binding NombreComun}"
                                       FontSize="16"
                                       FontAttributes="Bold"/>
                                <Label Text="{Binding CapitalTexto}"
                                       FontSize="13"
                                       TextColor="Gray"/>
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>
</ContentPage>